# Conduit Backend — stg profile env template (ADR-0037 v1.1)
SPRING_PROFILES_ACTIVE=stg
SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5433/conduit_stg
DB_USER=conduit_stg
DB_PASSWORD=<set-from-secret-manager>

JWT_SECRET=<set-from-secret-manager-256bit-min>
JWT_EXPIRATION_HOURS=168

CORS_ALLOWED_ORIGINS=https://stg.example.com
