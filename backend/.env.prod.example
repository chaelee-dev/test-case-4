# Conduit Backend — prod profile env template (ADR-0037 v1.1)
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

DB_URL=jdbc:postgresql://localhost:5434/conduit_prod
DB_USER=conduit_prod
DB_PASSWORD=<set-from-secret-manager>

JWT_SECRET=<set-from-secret-manager-256bit-min>
JWT_EXPIRATION_HOURS=168

CORS_ALLOWED_ORIGINS=https://app.example.com
